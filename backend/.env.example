# ============================================
# SIGPOL - Variáveis de Ambiente
# NUNCA versionar o arquivo .env real!
# ============================================

# Servidor
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sigpol
DB_USER=sigpol_user
DB_PASSWORD=TROCAR_SENHA_FORTE_AQUI
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# JWT (Auth)
JWT_SECRET=TROCAR_POR_STRING_ALEATORIA_256_BITS
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logs
LOG_LEVEL=info
LOG_DIR=./logs

# CORS (separar por vírgula para múltiplas origens)
CORS_ORIGINS=http://localhost:3000

# Upload de arquivos (fotos, documentos)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
